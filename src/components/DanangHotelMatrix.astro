        title: "美溪北段",
        cls: "north",
        desc: "海景城市酒店最密集，佩尼苏拉、希尔顿花园、M、福朋都在这条线。"
      },
      middle: {
        title: "美溪中南段",
        cls: "middle",
        desc: "更偏生活感和性价比，巴黎德利、TMS、HAIAN、Monarque 适合控预算。"
      },
      south: {
        title: "南线 Resort",
        cls: "south",
        desc: "更接近度假村逻辑，也更顺路去会安，但预算压力会明显变大。"
      }
    };

    zoneMap.innerHTML = "";
    Object.entries(groups).forEach(([key, meta]) => {
      const card = document.createElement("div");
      card.className = `zone-card ${meta.cls}`;
      const items = hotels
        .filter((hotel) => zoneGroup(hotel) === key)
        .map((hotel) => `<span class="chip">${hotel.zh}<strong>${hotel.fitTag}</strong></span>`)
        .join("");
      card.innerHTML = `
        <h3>${meta.title}</h3>
        <p>${meta.desc}</p>
        <div class="chip-list">${items}</div>
      `;
      zoneMap.appendChild(card);
    });
  }

  function renderCombos() {
    comboGrid.innerHTML = "";
    combos.forEach((combo) => {
      const card = document.createElement("div");
      card.className = "combo-card";
      card.innerHTML = `
        <h4>${combo.title}</h4>
        <div class="combo-total">总价约 ¥${combo.total}</div>
        <div class="combo-sub">${combo.type} | 平均约 ¥${combo.avg}/晚</div>
        <div class="combo-sub">每晚价格：${combo.nightly.join(" · ")}</div>
        <ul>${combo.route.map((item) => `<li>${item}</li>`).join("")}</ul>
        <div class="combo-note">${combo.reason}</div>
      `;
      comboGrid.appendChild(card);
    });
  }

  function filteredHotels() {
    const keyword = searchInput.value.trim().toLowerCase();

    return hotels.filter((hotel) => {
      const fitClasses = hotel.fitClass.split(" ");
      const usePass =
        activeUseFilters.size === 0 ||
        [...activeUseFilters].some((filter) => fitClasses.includes(filter));
      const xhsPass = activeXhsFilters.size === 0 || activeXhsFilters.has(hotel.xhsLevel);
      const refs = getLinks(hotel)
        .map((item) => item.label)
        .join(" ");
      const text = `${hotel.zh} ${hotel.en} ${hotel.zone} ${hotel.xhs} ${hotel.fitTag} ${refs}`.toLowerCase();
      const keywordPass = !keyword || text.includes(keyword);
      return usePass && xhsPass && keywordPass;
    });
  }

  function renderTable(items) {
    body.innerHTML = "";

    items.forEach((hotel) => {
      const refs = getLinks(hotel);
      const refHtml = refs
        .map(
          (item, index) =>
            `<a href="${item.url}" target="_blank" rel="noopener" class="${index === 0 ? "primary" : ""}">${item.label}</a>`
        )
        .join("");
      const bullets = summaryBullets(hotel.xhs).map((item) => `<li>${item}</li>`).join("");
      const row = document.createElement("tr");
      row.innerHTML = `
        <td class="hotel">
          <div class="cn">${hotel.zh}</div>
          <div class="en">${hotel.en}</div>
        </td>
        <td class="zone">${hotel.zone}</td>
        <td class="price">${hotel.prices[0]}</td>
        <td class="price">${hotel.prices[1]}</td>
        <td class="price">${hotel.prices[2]}</td>
        <td class="price">${hotel.prices[3]}</td>
        <td class="price">${hotel.prices[4]}</td>
        <td class="price">${hotel.prices[5]}</td>
        <td><span class="signal ${hotel.xhsLevel}">${signalLabel(hotel.xhsLevel)}</span></td>
        <td class="summary"><ul>${bullets}</ul></td>
        <td class="links">${refHtml}</td>
        <td class="fit">
          <span class="tag">${hotel.fitTag}</span>
        </td>
        <td class="actions links">
          <a href="${bookingUrl(hotel)}" target="_blank" rel="noopener" class="primary">携程详情</a>
          <a href="${tripadvisorUrl(hotel)}" target="_blank" rel="noopener">Tripadvisor 中文</a>
        </td>
      `;
      body.appendChild(row);
    });
  }

  function renderMobile(items) {
    mobileList.innerHTML = "";

    items.forEach((hotel) => {
      const refs = getLinks(hotel)
        .map(
          (item, index) =>
            `<a href="${item.url}" target="_blank" rel="noopener" class="${index === 0 ? "primary" : ""}">${item.label}</a>`
        )
        .join("");
      const bullets = summaryBullets(hotel.xhs).map((item) => `<li>${item}</li>`).join("");
      const priceLabels = ["5/2", "5/3", "5/4", "5/5", "5/6", "均价"];
      const priceGrid = hotel.prices
        .map(
          (price, index) => `
            <div class="mobile-price-item">
              <span>${priceLabels[index]}</span>
              <strong>${price}</strong>
            </div>
          `
        )
        .join("");

      const card = document.createElement("article");
      card.className = "mobile-card";
      card.innerHTML = `
        <div class="mobile-card-head">
          <div>
            <h3>${hotel.zh}</h3>
            <p>${hotel.en}</p>
          </div>
          <span class="signal ${hotel.xhsLevel}">${signalLabel(hotel.xhsLevel)}</span>
        </div>
        <div class="mobile-tags">
          <span class="tag">${hotel.fitTag}</span>
          <span class="tag muted-tag">${hotel.zone}</span>
        </div>
        <div class="mobile-price-grid">${priceGrid}</div>
        <div class="mobile-summary">
          <h4>小红书细节</h4>
          <ul>${bullets}</ul>
        </div>
        <div class="mobile-links links">${refs}</div>
        <div class="mobile-links links">
          <a href="${bookingUrl(hotel)}" target="_blank" rel="noopener" class="primary">携程详情</a>
          <a href="${tripadvisorUrl(hotel)}" target="_blank" rel="noopener">Tripadvisor 中文</a>
        </div>
      `;
      mobileList.appendChild(card);
    });
  }

  function render() {
    const items = filteredHotels();
    renderTable(items);
    renderMobile(items);
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const group = button.dataset.group;
      const filter = button.dataset.filter;
      const targetSet = group === "use" ? activeUseFilters : activeXhsFilters;
      const groupButtons = buttons.filter((candidate) => candidate.dataset.group === group);
      const allButton = groupButtons.find((candidate) => candidate.dataset.filter === "all");

      if (filter === "all") {
        targetSet.clear();
      } else if (targetSet.has(filter)) {
        targetSet.delete(filter);
      } else {
        targetSet.add(filter);
      }

      groupButtons.forEach((candidate) => {
        if (candidate.dataset.filter === "all") {
          candidate.classList.toggle("active", targetSet.size === 0);
        } else {
          candidate.classList.toggle("active", targetSet.has(candidate.dataset.filter));
        }
      });

      if (allButton) {
        allButton.classList.toggle("active", targetSet.size === 0);
      }

      render();
    });
  });

  searchInput.addEventListener("input", render);
  renderMap();
  renderCombos();
  render();
</script>

