  function signalLabel(level) {
    if (level === "strong") return "强";
    if (level === "medium") return "中";
    return "弱";
  }

  function getLinks(hotel) {
    return xhsReferenceMap[hotel.en] || [
      {
        label: "小红书搜索",
        url: `https://www.xiaohongshu.com/search_result?keyword=${encodeURIComponent(`${hotel.zh} ${hotel.en}`)}`
      }
    ];
  }

  function bookingUrl(hotel) {
    return hotel.ctrip || `https://hotels.ctrip.com/hotels/list?keyword=${encodeURIComponent(hotel.en)}`;
  }

  function tripadvisorUrl(hotel) {
    return `https://www.tripadvisor.cn/Search?q=${encodeURIComponent(`${hotel.en} ${hotel.zh}`)}`;
  }

  function zoneGroup(hotel) {
    if (hotel.fitClass.includes("resort")) return "south";
    if (hotel.fitClass.includes("city")) return "city";
    if (hotel.zone.includes("北段") || hotel.zone.includes("山茶")) return "north";
    return "middle";
  }

  function summaryBullets(text) {
    return text
      .replace(/^强：|^中：|^弱：|^弱-中：/g, "")
      .split("；")
      .filter(Boolean);
  }

